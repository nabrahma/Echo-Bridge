# ============================================================
# EchoBridge — Environment Variable Reference
# Copy relevant sections to .env.local (web) or .env (signaling)
# NEVER commit .env or .env.local to version control.
# ============================================================

# ── apps/web → .env.local ───────────────────────────────────
# WebSocket URL for the signaling server
# Local dev:    ws://localhost:4000
# Production:   wss://your-signaling-service.onrender.com
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:4000

# Public URL of this frontend app (used for QR code generation)
# Local dev:    http://localhost:3000
# Production:   https://echobridge.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ICE servers for WebRTC (JSON array string)
# Leave empty to use browser defaults (STUN only, works on LAN)
# Production: include TURN server credentials here
NEXT_PUBLIC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# ── apps/signaling → .env ───────────────────────────────────
# Port the signaling WebSocket server listens on
PORT=4000

# Allowed origins for CORS (comma-separated)
# Local dev:    http://localhost:3000
# Production:   https://echobridge.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Max age for idle rooms in milliseconds (default: 2 hours)
ROOM_MAX_AGE_MS=7200000
